{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2022",
		"lib": [
			"ES2022"
		],
		"sourceMap": true,
		"rootDir": "src",
		"strict": true,
		"useUnknownInCatchVariables": false,
		"skipLibCheck": true
	},
	"exclude": [
		"node_modules",
		".vscode-test",
		"webview",
		"scripts"
	]
}