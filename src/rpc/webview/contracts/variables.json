{
  "$schema": "./schema/webview-rpc-contract.schema.json",
  "domain": "variables",
  "declarations": [
    {
      "kind": "interface",
      "name": "Variable",
      "fields": [
        {
          "name": "name",
          "type": "string"
        },
        {
          "name": "path",
          "type": "string[]"
        },
        {
          "name": "type",
          "type": "string"
        },
        {
          "name": "value",
          "type": "string"
        },
        {
          "name": "size",
          "optional": true,
          "type": "number"
        },
        {
          "name": "hasChildren",
          "type": "boolean"
        },
        {
          "name": "kind",
          "optional": true,
          "type": "string"
        },
        {
          "name": "hasViewer",
          "optional": true,
          "type": "boolean"
        }
      ]
    },
    {
      "kind": "request",
      "name": "ListVariablesRequest",
      "method": "variables/list",
      "paramsType": "Params",
      "resultType": "Result",
      "errorType": "void",
      "declarations": [
        {
          "kind": "interface",
          "name": "Params",
          "fields": [
            {
              "name": "sessionId",
              "optional": true,
              "type": "string"
            }
          ]
        },
        {
          "kind": "interface",
          "name": "Result",
          "fields": [
            {
              "name": "variables",
              "type": "Variable[]"
            }
          ]
        }
      ]
    },
    {
