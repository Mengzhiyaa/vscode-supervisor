      "name": "InspectVariableRequest",
      "method": "variables/inspect",
      "paramsType": "Params",
      "resultType": "Result",
      "errorType": "void",
      "declarations": [
        {
          "kind": "interface",
          "name": "Params",
          "fields": [
            {
              "name": "path",
              "type": "string[]"
            },
            {
              "name": "sessionId",
              "optional": true,
              "type": "string"
            }
          ]
        },
        {
          "kind": "interface",
          "name": "Result",
          "fields": [
            {
              "name": "children",
              "type": "Variable[]"
            },
            {
              "name": "length",
              "optional": true,
              "type": "number"
