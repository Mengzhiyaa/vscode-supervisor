          "type": "'idle' | 'busy' | 'disconnected'"
        },
        {
          "name": "grouping",
          "type": "'none' | 'kind' | 'size'"
        },
        {
          "name": "sorting",
          "type": "'name' | 'size' | 'recent'"
        },
        {
          "name": "filterText",
          "type": "string"
        },
        {
          "name": "highlightRecent",
          "type": "boolean"
        }
